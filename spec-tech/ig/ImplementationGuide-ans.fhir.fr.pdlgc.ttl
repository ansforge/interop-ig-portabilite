       ] ;
       fhir:ImplementationGuide.definition.resource.name [ fhir:value "PDLGC Fournisseur Destinataire" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Editeur recevant les données en vue de leur intégration. Il est tenu d'une obligation de moyens pour l'import dès lors que le format est conforme au référentiel." ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]

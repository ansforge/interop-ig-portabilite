       fhir:ImplementationGuide.definition.resource.name [ fhir:value "PDLGC Demandeur" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Demandeur de l'export.\n\nIl peut s'agir d'un médecin ou professionnel de santé libéral, responsable du contenu médical transféré.\n\nIl peut également s'agir du patient lui-même, bénéficiaire de ses droits de portabilité individuelle (RGPD Art. 20, Art. L.1111-7 CSP)" ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
     ], [
